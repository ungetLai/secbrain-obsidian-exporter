# Required Configuration
# PostgreSQL connection string for SecBrain database (hosted on Zeabur)
DATABASE_URL=postgresql://user:password@host:port/database

# Local NAS path to Obsidian vault's "00 Inbox" folder
OBSIDIAN_INBOX_PATH=/path/to/obsidian/vault/00 Inbox

# Optional Configuration
# Maximum number of notes to export in one run (default: 100)
EXPORT_BATCH_SIZE=100

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Dry run mode - fetch and log but don't actually write files or update DB (default: false)
DRY_RUN=false

# Path to lock file for preventing concurrent execution (default: /tmp/secbrain-exporter.lock)
LOCK_FILE_PATH=/tmp/secbrain-exporter.lock
